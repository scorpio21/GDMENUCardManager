<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="350"
        x:Class="GDMENUCardManager.SdHealthWindow"
        Title="{DynamicResource StringSdHealth}" Width="450" Height="380" CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{DynamicResource StringSdHealth}" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Spacing="10">
            <Grid ColumnDefinitions="170,*">
                <TextBlock Grid.Column="0" Text="{DynamicResource StringHealthStatus}" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" x:Name="TxtHealth" Text="-"/>
            </Grid>
            <Grid ColumnDefinitions="170,*">
                <TextBlock Grid.Column="0" Text="{DynamicResource StringOperationalStatus}" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" x:Name="TxtOperational" Text="-"/>
            </Grid>
            <Grid ColumnDefinitions="170,*">
                <TextBlock Grid.Column="0" Text="{DynamicResource StringWriteSpeed}" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" x:Name="TxtWriteSpeed" Text="-"/>
            </Grid>
            <Grid ColumnDefinitions="170,*">
                <TextBlock Grid.Column="0" Text="{DynamicResource StringReadSpeed}" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" x:Name="TxtReadSpeed" Text="-"/>
            </Grid>
            <Grid ColumnDefinitions="170,*">
                <TextBlock Grid.Column="0" Text="{DynamicResource StringIntegrityTest}" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" x:Name="TxtIntegrity" Text="-"/>
            </Grid>

            <TextBlock x:Name="TxtWarning" Text="{DynamicResource StringFakeCardWarning}" Foreground="Red" FontWeight="Bold" IsVisible="False" Margin="0,10,0,0" TextWrapping="Wrap"/>
            <TextBlock x:Name="TxtError" Text="" Foreground="Red" TextWrapping="Wrap" Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Spacing="10">
            <ProgressBar x:Name="ProgressBar" Height="20" Minimum="0" Maximum="1" Value="0" IsVisible="False"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" x:Name="TxtStatus" Text="" VerticalAlignment="Center" IsVisible="False" Margin="0,0,10,0" TextWrapping="Wrap"/>
                <Button Grid.Column="1" x:Name="BtnRun" Content="{DynamicResource StringRunDiagnostics}" Click="BtnRun_Click" Width="150" HorizontalContentAlignment="Center"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
