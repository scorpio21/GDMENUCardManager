<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="680" d:DesignHeight="400"
        x:Class="GDMENUCardManager.AboutWindow"
        Title="{DynamicResource StringAboutTitle}" SizeToContent="Height" Width="680" CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Viewbox x:Key="ViewOpenInNew" Width="12" Height="12">
            <Canvas Width="24" Height="24">
                <Path Fill="Black" Data="M14,3V5H17.59L7.76,14.83L9.17,16.24L19,6.41V10H21V3M19,19H5V5H12V3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V12H19V19Z" />
            </Canvas>
        </Viewbox>
    </Window.Resources>
    <Grid Margin="15">
        <StackPanel>
            <!-- Header -->
            <TextBlock FontWeight="Bold" FontSize="16">GD MENU Card Manager - by Sonik (scorpio21 version)</TextBlock>
            <TextBlock Margin="0,2,0,0" Text="{DynamicResource StringAboutDescription}" />
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock>https://github.com/DerekPascarella/openMenu-Virtual-Folder-Bundle</TextBlock>
                <Button Margin="5,0,0,0" ToolTip.Tip="Open Link" Padding="2" Background="Transparent" BorderBrush="Transparent" Click="ButtonLink_Click">
                    <ContentControl Content="{StaticResource ViewOpenInNew}"/>
                </Button>
            </StackPanel>

            <Rectangle Fill="Gray" Height="1" Margin="0,12"/>

            <!-- Two-column content -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Vertical separator -->
                <Rectangle Grid.Column="1" Width="1" Fill="Gray" HorizontalAlignment="Center"/>

                <!-- Left Column -->
                <StackPanel Grid.Column="0">
                    <!-- Supported Formats -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap" Text="{DynamicResource StringSupportedFormats}" />
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{DynamicResource StringImage}" />
                        <TextBlock Grid.Row="0" Grid.Column="1">GDI, CDI, CCD, MDS, CUE/BIN</TextBlock>
                        <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Text="{DynamicResource StringCompressed}" />
                        <TextBlock Grid.Row="1" Grid.Column="1">7Z, CHD, RAR, ZIP</TextBlock>
                    </Grid>

                    <Rectangle Fill="Gray" Height="1" Margin="0,12"/>

                    <!-- Keyboard Shortcuts -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap" Text="{DynamicResource StringKeyboardShortcuts}" />
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{DynamicResource StringDelete}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{DynamicResource StringRemoveItems}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Text="{DynamicResource StringEscape}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{DynamicResource StringCloseWindow}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="SemiBold" Text="{DynamicResource StringF2}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{DynamicResource StringRenameSelected}" />
                        <TextBlock Grid.Row="3" Grid.Column="0" FontWeight="SemiBold" Text="{DynamicResource StringUndoRedo}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{DynamicResource StringUndoRedo}" />
                    </Grid>

                    <Rectangle Fill="Gray" Height="1" Margin="0,12"/>

                    <!-- Managing Games -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap" Text="{DynamicResource StringManagingGames}" />
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{DynamicResource StringAdd}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{DynamicResource StringDragDrop}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Text="{DynamicResource StringRemove}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{DynamicResource StringRemoveKey}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="SemiBold" Text="{DynamicResource StringReorder}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{DynamicResource StringUpDownButtons}" />
                        <TextBlock Grid.Row="3" Grid.Column="0" FontWeight="SemiBold" Text="{DynamicResource StringSort}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{DynamicResource StringSortListButton}" />
                    </Grid>

                    <Rectangle Fill="Gray" Height="1" Margin="0,12"/>

                    <!-- Renaming -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap" Text="{DynamicResource StringSingleBulkRenaming}" />
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{DynamicResource StringManual}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{DynamicResource StringRenamingManualDesc}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Text="{DynamicResource StringAuto}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{DynamicResource StringRenamingAutoDesc}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="SemiBold" Text="{DynamicResource StringCase}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{DynamicResource StringRenamingCaseDesc}" />
                    </Grid>

                </StackPanel>

                <!-- Right Column -->
                <StackPanel Grid.Column="2">
                    <!-- Folder Paths -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap" Text="{DynamicResource StringFolderPathsOpenMenu}" />
                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{DynamicResource StringFolderPathsDesc}" />

                    <Rectangle Fill="Gray" Height="1" Margin="0,12"/>

                    <!-- Artwork -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap" Text="{DynamicResource StringArtworkOpenMenu}" />
                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{DynamicResource StringArtworkDesc}" />

                    <Rectangle Fill="Gray" Height="1" Margin="0,12"/>

                    <!-- DAT Tools -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap" Text="{DynamicResource StringDatToolsOpenMenu}" />
                    <TextBlock Margin="0,4,0,0" Text="{DynamicResource StringImportDatEntriesDesc}" />
                    <TextBlock Text="{DynamicResource StringExportArtwork}" />
                    <TextBlock Text="{DynamicResource StringClearDatEntries}" />
                    <TextBlock Text="{DynamicResource StringOverwriteDatsDesc}" />

                    <Rectangle Fill="Gray" Height="1" Margin="0,12"/>

                    <!-- Disc Image Options -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap" Text="{DynamicResource StringDiscImageOptions}" />
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold" Text="{DynamicResource StringVgaPatch}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{DynamicResource StringForceVga}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Text="{DynamicResource StringRegionFree}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{DynamicResource StringBootOutOfRegion}" />
                    </Grid>

                    <Rectangle Fill="Gray" Height="1" Margin="0,12"/>

                    <!-- File/Folder Lock Check -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap" Text="{DynamicResource StringFileFolderLockCheck}" />
                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Text="{DynamicResource StringLockCheckDesc}" />
                </StackPanel>
            </Grid>

            <Rectangle Fill="Gray" Height="1" Margin="0,12"/>

            <!-- Credits -->
            <TextBlock FontWeight="Bold" TextWrapping="Wrap" Text="{DynamicResource StringCredits}" />
            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap">GDEMU - Deunan; gdMenu - neuroacid; openMenu - mrneo240; Virtual Folders - Derek Pascarella; GdiBuilder - Paul Kratt; Aaru - Natalia Portillo; PuyoTools - Nick Woronekin; Redump2CDI - darc; gdidrop - feyris-tan; libchdr - Romain Tisserand; ImageSharp - SixLabors; ClosedXML - Jan Havlíček; SharpCompress - Adam Hathcock</TextBlock>
        </StackPanel>

        <!-- Check for Updates button (top-right, rendered after StackPanel so it's on top for clicks) -->
        <Button Click="CheckForUpdatesButton_Click"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Height="28" Padding="12 0">
            <TextBlock Text="{DynamicResource StringCheckForUpdates}" />
        </Button>
    </Grid>
</Window>
