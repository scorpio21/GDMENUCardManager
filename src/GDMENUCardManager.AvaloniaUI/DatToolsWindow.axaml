<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="870" d:DesignHeight="400"
        x:Class="GDMENUCardManager.DatToolsWindow"
        Title="{DynamicResource StringDatTools}" SizeToContent="Height" Width="655" CanResize="False"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="10">
    <TabControl>
      <TabControl.Styles>
        <Style Selector="TabControl /template/ ItemsPresenter#PART_ItemsPresenter">
          <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TabItem">
          <Setter Property="FontSize" Value="12"/>
        </Style>
      </TabControl.Styles>
      <!-- Import DAT Entries Tab -->
      <TabItem Header="{DynamicResource StringImportDatEntries}">
        <Grid Margin="10">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <!-- Instructions -->
          <StackPanel Grid.Row="0" Margin="0,0,0,15">
          <TextBlock TextWrapping="Wrap" Foreground="Black" FontWeight="Bold" Text="{DynamicResource StringImportMergeBold}"/>
          <TextBlock x:Name="TextImportInstructions" TextWrapping="Wrap" Foreground="Black" Margin="0,8,0,0" Text="{DynamicResource StringImportInstructions}"/>
          </StackPanel>

          <!-- Radio buttons for import mode -->
          <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <RadioButton x:Name="RadioImportMissing" Content="{DynamicResource StringImportOnlyMissing}" IsChecked="True" Foreground="Black"/>
            <RadioButton x:Name="RadioImportAll" Content="{DynamicResource StringImportAllOverwrite}" Foreground="Black"/>
          </StackPanel>

          <!-- Source folder display -->
          <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
            <TextBlock Text="{DynamicResource StringSourceColon}" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold" Margin="0,0,5,0"/>
            <TextBlock x:Name="TextImportSourcePath" Text="{DynamicResource StringNoFolderSelected}" VerticalAlignment="Center"
                       Foreground="Gray" MaxWidth="450" TextTrimming="CharacterEllipsis"/>
          </StackPanel>

          <!-- Buttons -->
          <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Click="ChooseImportFolder_Click" Padding="15,8" Margin="0,0,10,0">
              <TextBlock Text="{DynamicResource StringChooseDatFolder}" />
            </Button>
            <Button x:Name="ButtonBeginImport" Click="BeginImport_Click"
                    Padding="15,8" IsEnabled="False">
              <TextBlock Text="{DynamicResource StringBeginImport}" />
            </Button>
          </StackPanel>
        </Grid>
      </TabItem>

      <!-- Export Artwork to PNGs Tab -->
      <TabItem Header="{DynamicResource StringExportArtworkPngs}">
        <Grid Margin="10">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <!-- Instructions -->
          <StackPanel Grid.Row="0" Margin="0,0,0,15">
          <TextBlock TextWrapping="Wrap" Foreground="Black" FontWeight="Bold" Text="{DynamicResource StringExportArtworkBold}"/>
          <TextBlock TextWrapping="Wrap" Foreground="Black" Margin="0,8,0,0" Text="{DynamicResource StringExportArtworkSyntax}"/>
          </StackPanel>

          <!-- Target folder display -->
          <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
            <TextBlock Text="{DynamicResource StringTargetColon}" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold" Margin="0,0,5,0"/>
            <TextBlock x:Name="TextExportTargetPath" Text="{DynamicResource StringNoFolderSelected}" VerticalAlignment="Center"
                       Foreground="Gray" MaxWidth="450" TextTrimming="CharacterEllipsis"/>
          </StackPanel>

          <!-- Buttons -->
          <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Click="ChooseExportFolder_Click" Padding="15,8" Margin="0,0,10,0">
              <TextBlock Text="{DynamicResource StringChooseTargetFolder}" />
            </Button>
            <Button x:Name="ButtonBeginExport" Click="BeginExport_Click"
                    Padding="15,8" IsEnabled="False">
              <TextBlock Text="{DynamicResource StringBeginExport}" />
            </Button>
          </StackPanel>
        </Grid>
      </TabItem>

      <!-- Clear All DAT Entries Tab -->
      <TabItem Header="{DynamicResource StringClearAllDatEntries}">
        <Grid Margin="10">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <!-- Instructions -->
          <StackPanel Grid.Row="0" Margin="0,0,0,15">
          <TextBlock TextWrapping="Wrap" Foreground="Black" FontWeight="Bold" Text="{DynamicResource StringClearArtworkMetadataBold}"/>
          <TextBlock x:Name="TextClearInstructions" TextWrapping="Wrap" Foreground="Black" Margin="0,8,0,0" Text="{DynamicResource StringClearInstructions}"/>
          </StackPanel>

          <!-- Button -->
          <Button Grid.Row="1" Click="ClearDats_Click"
                  Padding="15,8" HorizontalAlignment="Right">
            <TextBlock Text="{DynamicResource StringClearDats}" />
          </Button>
        </Grid>
      </TabItem>
      <!-- Overwrite DATs With SD Card Tab -->
      <TabItem Header="{DynamicResource StringOverwriteDatsWithSd}">
        <Grid Margin="10">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <!-- Instructions -->
          <StackPanel Grid.Row="0" Margin="0,0,0,15">
          <TextBlock TextWrapping="Wrap" Foreground="Black" FontWeight="Bold" Text="{DynamicResource StringOverwriteLocalDatsBold}"/>
          <TextBlock x:Name="TextOverwriteInstructions" TextWrapping="Wrap" Foreground="Black" Margin="0,8,0,0" Text="{DynamicResource StringOverwriteInstructions}"/>
          </StackPanel>

          <!-- Button -->
          <Button Grid.Row="1" Click="OverwriteDats_Click"
                  Padding="15,8" HorizontalAlignment="Right">
            <TextBlock Text="{DynamicResource StringOverwriteDats}" />
          </Button>
        </Grid>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
