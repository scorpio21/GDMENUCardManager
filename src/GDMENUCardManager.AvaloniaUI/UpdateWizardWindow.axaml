<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="350"
        x:Class="GDMENUCardManager.UpdateWizardWindow"
        Title="{DynamicResource StringUpdateWizard}" SizeToContent="Height" Width="500"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="20">
    <!-- Page 1: Preservation Options -->
    <StackPanel x:Name="Page1" IsVisible="True">
      <TextBlock TextWrapping="Wrap" Margin="0 0 0 10" Text="{DynamicResource StringChoosePreserve}"/>

      <StackPanel Margin="10 5 0 0">
        <CheckBox x:Name="ChkPreserveDats" IsChecked="True" Margin="0 4">
          <TextBlock Text="{DynamicResource StringPreserveArtwork}"/>
        </CheckBox>
        <CheckBox x:Name="ChkPreserveThemes" IsChecked="False" Margin="0 4">
          <TextBlock Text="{DynamicResource StringPreserveThemes}"/>
        </CheckBox>
        <CheckBox x:Name="ChkPreserveCheats" IsChecked="False" Margin="0 4">
          <TextBlock Text="{DynamicResource StringPreserveCheats}"/>
        </CheckBox>
        <CheckBox x:Name="ChkPreserveSettings" IsChecked="True" Margin="0 4">
          <TextBlock TextWrapping="Wrap" Text="{DynamicResource StringPreserveSettings}"/>
        </CheckBox>
      </StackPanel>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 20 0 0">
        <Button Click="CancelButton_Click" Width="90" Height="28" Margin="0 0 10 0">
          <TextBlock Text="{DynamicResource StringCancel}" />
        </Button>
        <Button Click="NextButton_Click" Width="90" Height="28" IsDefault="True">
          <TextBlock Text="{DynamicResource StringNext}" />
        </Button>
      </StackPanel>
    </StackPanel>

    <!-- Page 2: Download & Install -->
    <StackPanel x:Name="Page2" IsVisible="False">
      <TextBlock x:Name="StatusText" TextWrapping="Wrap" Margin="0 0 0 10"/>

      <ProgressBar x:Name="DownloadProgress" Height="22" Margin="0 0 0 5" Minimum="0" Maximum="100"/>

      <TextBlock x:Name="SpeedText" Margin="0 0 0 5" Foreground="Gray"/>
      <TextBlock x:Name="SizeText" Foreground="Gray"/>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 20 0 0">
        <Button x:Name="CancelDownloadButton" Click="CancelDownloadButton_Click" Width="90" Height="28" Margin="0 0 10 0">
          <TextBlock Text="{DynamicResource StringCancel}" />
        </Button>
        <Button x:Name="InstallButton" Click="InstallButton_Click" Width="110" Height="28" IsVisible="False">
          <TextBlock Text="{DynamicResource StringInstallNow}" />
        </Button>
      </StackPanel>
    </StackPanel>
  </Grid>
</Window>
