<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="400"
        x:Class="GDMENUCardManager.ArtworkWindow"
        Title="{Binding WindowTitle}" Width="420" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Serial ID -->
    <TextBlock Grid.Row="0" Text="{Binding Serial}" FontWeight="Bold" Foreground="Black"
               HorizontalAlignment="Center" Margin="0,0,0,10"/>

    <!-- Image Preview with Navigation Arrows -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="1*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Button Grid.Column="0" Click="NavigatePrev_Click"
              IsEnabled="{Binding CanNavigatePrev}"
              VerticalAlignment="Center" Width="30" Height="40" Padding="0">
        <Path Data="M 10,0 L 0,8 L 10,16" Stroke="Black" StrokeThickness="2"
              HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Button>

      <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1"
              Width="260" Height="260" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid>
          <TextBlock Text="{DynamicResource StringNoArtworkAssigned}" HorizontalAlignment="Center" VerticalAlignment="Center"
                     IsVisible="{Binding !HasPreviewImage}"/>
          <Image Source="{Binding PreviewImage}" Stretch="Uniform"
                 IsVisible="{Binding HasPreviewImage}"/>
        </Grid>
      </Border>

      <Button Grid.Column="2" Click="NavigateNext_Click"
              IsEnabled="{Binding CanNavigateNext}"
              VerticalAlignment="Center" Width="30" Height="40" Padding="0">
        <Path Data="M 0,0 L 10,8 L 0,16" Stroke="Black" StrokeThickness="2"
              HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Button>
    </Grid>

    <!-- Info Label -->
    <TextBlock Grid.Row="2" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,10,0,0" Foreground="Black"
               Text="{DynamicResource StringArtworkWarning}"/>

    <!-- Buttons -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
      <Button Click="BrowseImage_Click" Margin="0,0,10,0" Padding="15,8">
        <TextBlock Text="{DynamicResource StringBrowseForImage}" />
      </Button>
      <Button Click="DeleteEntry_Click" Margin="0,0,10,0" Padding="15,8"
              IsEnabled="{Binding CanDelete}">
        <TextBlock Text="{DynamicResource StringDeleteEntry}" />
      </Button>
      <Button Click="Apply_Click" Padding="15,8"
              IsEnabled="{Binding HasUnsavedChanges}">
        <TextBlock Text="{DynamicResource StringSave}" />
      </Button>
    </StackPanel>
  </Grid>
</Window>
