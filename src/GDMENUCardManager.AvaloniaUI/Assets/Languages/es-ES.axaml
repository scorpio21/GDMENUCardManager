  <x:String x:Key="StringConfirmImportTitle">Confirmar importación</x:String>
  <x:String x:Key="StringConfirmImportMsg">Esto hará una copia de seguridad de los archivos DAT actuales y combinará las entradas de la carpeta seleccionada.&#x0a;&#x0a;¿Continuar?</x:String>
  <x:String x:Key="StringContinue">Continuar</x:String>
  <x:String x:Key="StringExportingArtworkTitle">Exportando carátulas</x:String>
  <x:String x:Key="StringExporting">Exportando...</x:String>
  <x:String x:Key="StringExportFailed">Fallo en la exportación</x:String>
  <x:String x:Key="StringExportCompleteTitle">Exportación completada</x:String>
  <x:String x:Key="StringExportSuccessMsg">Se han exportado {0} archivo(s) de carátula a PNG.</x:String>
  <x:String x:Key="StringConfirmClearTitle">Confirmar limpieza</x:String>
  <x:String x:Key="StringConfirmClearMsg">Esto hará una copia de seguridad de los archivos DAT actuales y luego borrará TODAS las carátulas y metadatos.&#x0a;&#x0a;Esta acción no se puede deshacer. ¿Continuar?</x:String>
  <x:String x:Key="StringClearAll">Limpiar todo</x:String>
  <x:String x:Key="StringClearingDatFilesTitle">Limpiando archivos DAT</x:String>
  <x:String x:Key="StringClearing">Limpiando...</x:String>
  <x:String x:Key="StringClearFailed">Fallo en la limpieza</x:String>
  <x:String x:Key="StringClearCompleteTitle">Limpieza completada</x:String>
  <x:String x:Key="StringClearSuccessMsg">Se han borrado todas las entradas DAT.</x:String>
  <x:String x:Key="StringConfirmOverwriteTitle">Confirmar sobrescritura</x:String>
  <x:String x:Key="StringConfirmOverwriteMsg">Esto hará una copia de seguridad de los archivos DAT actuales y los sobrescribirá con los de la imagen de disco openMenu de la tarjeta SD.&#x0a;&#x0a;¿Continuar?</x:String>
  <x:String x:Key="StringOverwritingDatFilesTitle">Sobrescribiendo archivos DAT</x:String>
