  <x:String x:Key="StringViewChangelog">Ver historial de cambios</x:String>
  <x:String x:Key="StringUpdateWizardMsg">¿Te gustaría actualizar ahora? Un asistente de actualización te guiará por las opciones para conservar tus archivos actuales.</x:String>
  <x:String x:Key="StringRemindMeLater">Recordármelo más tarde</x:String>
  <x:String x:Key="StringUpdateNow">Actualizar ahora</x:String>
  <x:String x:Key="StringUpdateWizard">Asistente de actualización</x:String>
  <x:String x:Key="StringChoosePreserve">Elige cuáles de tus archivos actuales quieres conservar durante la actualización. Los elementos marcados NO se sobrescribirán.</x:String>
  <x:String x:Key="StringPreserveArtwork">Conservar carátulas y metadatos personalizados</x:String>
