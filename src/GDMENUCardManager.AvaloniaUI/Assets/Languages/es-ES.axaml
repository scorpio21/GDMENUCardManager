  <x:String x:Key="StringArtworkOpenMenu">Carátulas (modo openMenu)</x:String>
  <x:String x:Key="StringArtworkDesc">Haz clic en el botón Asignar/Gestionar en la columna Carátula para configurar la carátula.</x:String>
