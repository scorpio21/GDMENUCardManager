  <x:String x:Key="StringRetry">Retry</x:String>

  <!-- Metadata Scan Dialog -->
  <x:String x:Key="StringMetadataCacheRequired">Metadata Cache Required</x:String>
  <x:String x:Key="StringMetadataScanMsg1">Your SD card contains games that were added by an older version of this application (or another tool). These games are missing cached metadata files that are required for proper operation.</x:String>
  <x:String x:Key="StringMetadataScanMsg2">A one-time scan of all disc images will now be performed to:</x:String>
  <x:String x:Key="StringMetadataScanBullet1">• Read game properties from each disc image</x:String>
  <x:String x:Key="StringMetadataScanBullet2">• Cache metadata for faster loading in the future</x:String>
  <x:String x:Key="StringMetadataScanBullet3">• Ensure serial IDs display correctly for artwork matching</x:String>
  <x:String x:Key="StringMetadataScanFinal">This process cannot be skipped. Depending on the number of games and your drive speed, this may take a few minutes.</x:String>
  <x:String x:Key="StringGamesRequiringScan">Games requiring scan: </x:String>
