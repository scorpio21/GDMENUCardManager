<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="320"
        x:Class="GDMENUCardManager.MetadataScanDialog"
        Title="{DynamicResource StringMetadataCacheRequired}" SizeToContent="Height" Width="500"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Message -->
    <StackPanel Grid.Row="0">
      <TextBlock TextWrapping="Wrap" Margin="0 0 0 15" Text="{DynamicResource StringMetadataScanMsg1}"/>

      <TextBlock TextWrapping="Wrap" Margin="0 0 0 10" Text="{DynamicResource StringMetadataScanMsg2}"/>

      <StackPanel Margin="20 0 0 15">
        <TextBlock Text="{DynamicResource StringMetadataScanBullet1}"/>
        <TextBlock Text="{DynamicResource StringMetadataScanBullet2}"/>
        <TextBlock Text="{DynamicResource StringMetadataScanBullet3}"/>
      </StackPanel>

      <TextBlock TextWrapping="Wrap" Text="{DynamicResource StringMetadataScanFinal}"/>
    </StackPanel>

    <!-- Game count -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 10 0 20">
      <TextBlock Text="{DynamicResource StringGamesRequiringScan}"/>
      <TextBlock x:Name="GameCountText"/>
    </StackPanel>

    <!-- Buttons -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Click="QuitButton_Click" Width="90" Height="28" Margin="0 0 10 0">
        <TextBlock Text="{DynamicResource StringQuit}" />
      </Button>
      <Button Click="StartScanButton_Click" Width="90" Height="28" IsDefault="True">
        <TextBlock Text="{DynamicResource StringStartScan}" />
      </Button>
    </StackPanel>
  </Grid>
</Window>
