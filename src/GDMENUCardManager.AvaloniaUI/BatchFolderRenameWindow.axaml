<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GDMENUCardManager"
        xmlns:core="clr-namespace:GDMENUCardManager.Core;assembly=GDMENUCardManager.Core"
        xmlns:conv="clr-namespace:GDMENUCardManager.Converter"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="600"
        x:Class="GDMENUCardManager.BatchFolderRenameWindow"
        Title="{DynamicResource StringBatchFolderRename}" Height="600" Width="500"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,10">
      <TextBlock Text="{DynamicResource StringFolderHierarchy}" FontWeight="Bold" />
      <TextBlock TextWrapping="Wrap" Margin="0,5,0,0"
                 Text="{DynamicResource StringFolderHierarchyDesc}"/>
    </StackPanel>

    <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1">
      <TreeView Name="FolderTreeView"
                Items="{Binding RootNodes}">
        <TreeView.DataTemplates>
          <TreeDataTemplate DataType="core:FolderTreeNode" ItemsSource="{Binding Children}">
            <Border Name="ItemBorder"
                    Background="Transparent"
                    Padding="2"
                    CornerRadius="2"
                    DoubleTapped="TreeViewItem_DoubleTapped">
              <Grid>
                <TextBlock Text="{Binding DisplayName}"
                           IsVisible="{Binding !IsEditing}"/>
                <TextBox Text="{Binding Name, Mode=TwoWay}"
                         IsVisible="{Binding IsEditing}"
                         LostFocus="EditTextBox_LostFocus"
                         KeyDown="EditTextBox_KeyDown"
                         AttachedToVisualTree="EditTextBox_AttachedToVisualTree"/>
              </Grid>
            </Border>
          </TreeDataTemplate>
        </TreeView.DataTemplates>
        <TreeView.Styles>
          <Style Selector="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
          </Style>
        </TreeView.Styles>
      </TreeView>
    </Border>

    <Grid Grid.Row="2" Margin="0,10,0,0">
      <Button HorizontalAlignment="Left" Width="130" Padding="15,8"
              Click="UndoButton_Click" IsEnabled="{Binding CanUndo}">
        <TextBlock Text="{DynamicResource StringUndoLastChange}" />
      </Button>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Width="80" Padding="15,8" Margin="0,0,10,0" Click="SaveButton_Click">
          <TextBlock Text="{DynamicResource StringSave}" />
        </Button>
        <Button Width="80" Padding="15,8" Click="CancelButton_Click">
          <TextBlock Text="{DynamicResource StringCancel}" />
        </Button>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
