<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="150"
        x:Class="GDMENUCardManager.AssignFolderWindow"
        Title="{DynamicResource StringAssignFolder}" SizeToContent="Height" Width="400" CanResize="False"
        WindowStartupLocation="CenterOwner">
  <StackPanel Margin="15">
    <TextBlock Text="{Binding SelectionInfo}" Margin="0 0 0 15" FontWeight="Bold"/>

    <TextBlock Text="{DynamicResource StringFolderPathColon}" Margin="0 0 0 5"/>
    <TextBox x:Name="FolderInput"
             Text="{Binding FolderPath, Mode=TwoWay}"
             MaxLength="256"
             Watermark="{DynamicResource StringWatermarkFolderPath}"/>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 20 0 0">
      <Button Click="OkButton_Click" IsDefault="True" Width="80" Padding="15,8" Margin="0 0 10 0">
        <TextBlock Text="{DynamicResource StringOk}" />
      </Button>
      <Button Click="CancelButton_Click" IsCancel="True" Width="80" Padding="15,8">
        <TextBlock Text="{DynamicResource StringCancel}" />
      </Button>
    </StackPanel>
  </StackPanel>
</Window>
