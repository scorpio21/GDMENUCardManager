<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="330"
        x:Class="GDMENUCardManager.DiscImageOptionsWindow"
        Title="{DynamicResource StringDiscOptions}" Width="320" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" CanResize="False">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Card Boxes - Vertically Stacked -->
        <StackPanel Grid.Row="0" Orientation="Vertical" HorizontalAlignment="Stretch">

            <!-- VGA Patch Card -->
            <HeaderedContentControl Margin="0 0 0 10">
                <HeaderedContentControl.Header>
                    <TextBlock Text="{DynamicResource StringVgaPatch}" FontWeight="Bold"/>
                </HeaderedContentControl.Header>
                <StackPanel Margin="8">
                    <TextBlock Text="{DynamicResource StringVgaPatchDesc}" TextWrapping="Wrap"
                               Foreground="Gray" FontSize="11" Margin="0 0 0 10"/>
                    <CheckBox x:Name="ChkEnableVgaPatch" IsChecked="{Binding EnableVgaPatch}">
                        <TextBlock Text="{DynamicResource StringApplyToNewlyAdded}"/>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding EnableVgaPatchExisting}"
                              IsEnabled="{Binding IsChecked, ElementName=ChkEnableVgaPatch}" Margin="0 5 0 0">
                        <TextBlock Text="{DynamicResource StringApplyToExisting}"/>
                    </CheckBox>
                </StackPanel>
            </HeaderedContentControl>

            <!-- Region-Free Patch Card -->
            <HeaderedContentControl Margin="0">
                <HeaderedContentControl.Header>
                    <TextBlock Text="{DynamicResource StringRegionFreePatch}" FontWeight="Bold"/>
                </HeaderedContentControl.Header>
                <StackPanel Margin="8">
                    <TextBlock Text="{DynamicResource StringRegionFreePatchDesc}" TextWrapping="Wrap"
                               Foreground="Gray" FontSize="11" Margin="0 0 0 10"/>
                    <CheckBox x:Name="ChkEnableRegionPatch" IsChecked="{Binding EnableRegionPatch}">
                        <TextBlock Text="{DynamicResource StringApplyToNewlyAdded}"/>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding EnableRegionPatchExisting}"
                              IsEnabled="{Binding IsChecked, ElementName=ChkEnableRegionPatch}" Margin="0 5 0 0">
                        <TextBlock Text="{DynamicResource StringApplyToExisting}"/>
                    </CheckBox>
                </StackPanel>
            </HeaderedContentControl>
        </StackPanel>

        <!-- Save/Cancel Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 5 0 0">
            <Button Width="80" Padding="15,8" Margin="0 0 10 0" Click="SaveButton_Click">
                <TextBlock Text="{DynamicResource StringSave}" />
            </Button>
            <Button Width="80" Padding="15,8" Click="CancelButton_Click">
                <TextBlock Text="{DynamicResource StringCancel}" />
            </Button>
        </StackPanel>
    </Grid>
</Window>
