<Window x:Class="GDMENUCardManager.SerialTranslationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource StringSerialTranslationTitle}"
        SizeToContent="Height"
        Width="550"
        MinHeight="200"
        MaxHeight="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Message -->
        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,15" Text="{DynamicResource StringSerialTranslationMsg1}" />

        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,15">
            <Run Text="{DynamicResource StringSerialTranslationMsg2}"/>
            <LineBreak/><LineBreak/>
            <Run Text="{DynamicResource StringSerialTranslationMsg3}"/>
        </TextBlock>

        <!-- Checkbox list -->
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,15" MaxHeight="200">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="TranslationList" Padding="10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="0,3">
                                <TextBlock>
                                    <Run Text="{Binding OriginalSerial, Mode=OneWay}"/>
                                    <Run Text=" → "/>
                                    <Run Text="{Binding TranslatedSerial, Mode=OneWay}" FontWeight="SemiBold"/>
                                    <Run Text="  "/>
                                    <Run Text="{Binding GameName, Mode=OneWay}" Foreground="Gray"/>
                                </TextBlock>
                            </CheckBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Instruction -->
        <TextBlock Grid.Row="3" TextWrapping="Wrap" Margin="0,0,0,15" FontStyle="Italic" Foreground="Gray" Text="{DynamicResource StringSerialTranslationInstruct}"/>

        <!-- OK Button -->
        <Button Grid.Row="3" Content="{DynamicResource StringOk}" Width="80" HorizontalAlignment="Right"
                Padding="10,5" Click="OkButton_Click"/>
    </Grid>
</Window>
