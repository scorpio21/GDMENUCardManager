<Window x:Class="GDMENUCardManager.AssignAltFoldersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource StringAssignAltFolders}"
        SizeToContent="Height" Width="420" MinHeight="160" MaxHeight="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="15">
        <TextBlock Text="{Binding HeaderText}" Margin="0 0 0 15" FontWeight="Bold"/>

        <ItemsControl ItemsSource="{Binding AltFolders}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0 0 0 8">
                        <TextBlock Margin="0 0 0 3">
                            <Run Text="{DynamicResource StringFolderPathSpace}"/><Run Text="{Binding Index, Mode=OneWay}"/><Run Text=":"/>
                        </TextBlock>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="X" Width="26" Height="26"
                                    Margin="5 0 0 0" Click="RemoveButton_Click"
                                    VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding DataContext.KnownFolders, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Text="{Binding FolderPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                      IsEditable="True" MaxDropDownHeight="200"
                                      LostFocus="FolderPath_LostFocus"/>
                        </DockPanel>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button Content="{DynamicResource StringAddFolderPath}" Click="AddButton_Click"
                HorizontalAlignment="Left" Margin="0 0 0 0" Padding="15,8"
                IsEnabled="{Binding CanAddMore}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 20 0 0">
            <Button Content="{DynamicResource StringOk}" Click="OkButton_Click" IsDefault="True" Width="80" Padding="15,8" Margin="0 0 10 0"/>
            <Button Content="{DynamicResource StringCancel}" Click="CancelButton_Click" IsCancel="True" Width="80" Padding="15,8"/>
        </StackPanel>
    </StackPanel>
</Window>
