<Window x:Class="GDMENUCardManager.UpdateAvailableDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Update Available" SizeToContent="Height" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Message -->
        <StackPanel Grid.Row="0">
            <TextBlock TextWrapping="Wrap" Margin="0 0 0 10">
                <Run Text="A new version of GD MENU Card Manager ("/><Run x:Name="VersionText" FontWeight="SemiBold"/><Run Text=") is available."/>
            </TextBlock>

            <TextBlock Margin="0 0 0 15">
                <Hyperlink RequestNavigate="Changelog_RequestNavigate" NavigateUri="https://github.com/DerekPascarella/openMenu-Virtual-Folder-Bundle?tab=readme-ov-file#changelog">View Changelog</Hyperlink>
            </TextBlock>

            <TextBlock TextWrapping="Wrap" Text="Would you like to update now? An update wizard will walk you through options to preserve your current assets."/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 15 0 0">
            <Button Content="Skip This Version" Click="SkipButton_Click" Width="120" Height="28" Margin="0 0 10 0"/>
            <Button Content="Remind Me Later" Click="RemindButton_Click" Width="120" Height="28" Margin="0 0 10 0"/>
            <Button Content="Update Now" Click="UpdateButton_Click" Width="90" Height="28" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
