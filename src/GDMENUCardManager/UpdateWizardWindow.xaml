<Window x:Class="GDMENUCardManager.UpdateWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource StringUpdateWizard}" SizeToContent="Height" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <!-- Page 1: Preservation Options -->
        <StackPanel x:Name="Page1" Visibility="Visible">
            <TextBlock TextWrapping="Wrap" Margin="0 0 0 10" Text="{DynamicResource StringUpdatePreserveDesc}"/>

            <StackPanel Margin="10 5 0 0">
                <CheckBox x:Name="ChkPreserveDats" IsChecked="True" Margin="0 4">
                    <TextBlock Text="{DynamicResource StringPreserveDats}"/>
                </CheckBox>
                <CheckBox x:Name="ChkPreserveThemes" IsChecked="False" Margin="0 4">
                    <TextBlock Text="{DynamicResource StringPreserveThemes}"/>
                </CheckBox>
                <CheckBox x:Name="ChkPreserveCheats" IsChecked="False" Margin="0 4">
                    <TextBlock Text="{DynamicResource StringPreserveCheats}"/>
                </CheckBox>
                <CheckBox x:Name="ChkPreserveSettings" IsChecked="True" Margin="0 4">
                    <TextBlock TextWrapping="Wrap" Text="{DynamicResource StringPreserveSettingsDesc}"/>
                </CheckBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 20 0 0">
                <Button Content="{DynamicResource StringCancel}" Click="CancelButton_Click" Width="90" Height="28" Margin="0 0 10 0"/>
                <Button Content="{DynamicResource StringNext}" Click="NextButton_Click" Width="90" Height="28" IsDefault="True"/>
            </StackPanel>
        </StackPanel>

        <!-- Page 2: Download & Install -->
        <StackPanel x:Name="Page2" Visibility="Collapsed">
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Margin="0 0 0 10"/>

            <ProgressBar x:Name="DownloadProgress" Height="22" Margin="0 0 0 5" Minimum="0" Maximum="100"/>

            <TextBlock x:Name="SpeedText" Margin="0 0 0 5" Foreground="Gray"/>
            <TextBlock x:Name="SizeText" Foreground="Gray"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 20 0 0">
                <Button x:Name="CancelDownloadButton" Content="{DynamicResource StringCancel}" Click="CancelDownloadButton_Click" Width="90" Height="28" Margin="0 0 10 0"/>
                <Button x:Name="InstallButton" Content="{DynamicResource StringInstallNow}" Click="InstallButton_Click" Width="90" Height="28" Visibility="Collapsed"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
