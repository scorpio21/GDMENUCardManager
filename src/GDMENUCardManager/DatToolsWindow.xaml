<Window x:Class="GDMENUCardManager.DatToolsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource StringDatTools}" SizeToContent="Height" Width="595" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <TabControl>
            <!-- Import DAT Entries Tab -->
            <TabItem Header="{DynamicResource StringImportDatEntries}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Instructions -->
                    <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,15" Foreground="Black" xml:space="preserve"><Run FontWeight="Bold" Text="{DynamicResource StringImportDatDesc1}"/><LineBreak/><LineBreak/><Run Text="{DynamicResource StringImportDatDesc2}"/><LineBreak/><LineBreak/><Run Text="{DynamicResource StringImportDatDesc3}"/><Run FontWeight="Bold" Text="{DynamicResource StringChooseDatFolder}"/><Run Text="{DynamicResource StringImportDatDesc5}"/><LineBreak/><LineBreak/><Run Text="{DynamicResource StringImportDatDesc6}"/><Run FontWeight="Bold" Text="{DynamicResource StringBeginImport}"/><Run Text="{DynamicResource StringImportDatDesc8}"/><LineBreak/><LineBreak/><Run Text="{DynamicResource StringImportDatDesc9}"/></TextBlock>

                    <!-- Radio buttons for import mode -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,15">
                        <RadioButton x:Name="RadioImportMissing" Content="{DynamicResource StringImportMissing}" IsChecked="True" Foreground="Black"/>
                        <RadioButton x:Name="RadioImportAll" Content="{DynamicResource StringImportAll}" Foreground="Black"/>
                    </StackPanel>

                    <!-- Source folder display -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <TextBlock Text="{DynamicResource StringSource}" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold"/>
                        <TextBlock x:Name="TextImportSourcePath" Text="{DynamicResource StringNoFolderSelected}" VerticalAlignment="Center"
                                   Foreground="Gray" MaxWidth="450" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{DynamicResource StringChooseDatFolder}" Click="ChooseImportFolder_Click" Padding="15,8" Margin="0,0,10,0"/>
                        <Button x:Name="ButtonBeginImport" Content="{DynamicResource StringBeginImport}" Click="BeginImport_Click"
                                Padding="15,8" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Export Artwork to PNGs Tab -->
            <TabItem Header="{DynamicResource StringExportArtwork}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Instructions -->
                    <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,15" Foreground="Black" xml:space="preserve"><Run FontWeight="Bold" Text="{DynamicResource StringExportArtworkDesc1}"/><LineBreak/><LineBreak/><Run Text="{DynamicResource StringExportArtworkDesc2}"/><Run FontWeight="Bold" Text="{DynamicResource StringExportArtworkDesc3}"/><LineBreak/><LineBreak/><Run Text="{DynamicResource StringExportArtworkDesc4}"/><Run FontWeight="Bold" Text="{DynamicResource StringBeginExport}"/><Run Text="{DynamicResource StringImportDatDesc8}"/></TextBlock>

                    <!-- Target folder display -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                        <TextBlock Text="{DynamicResource StringTarget}" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold"/>
                        <TextBlock x:Name="TextExportTargetPath" Text="{DynamicResource StringNoFolderSelected}" VerticalAlignment="Center"
                                   Foreground="Gray" MaxWidth="450" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="{DynamicResource StringChooseTargetFolder}" Click="ChooseExportFolder_Click" Padding="15,8" Margin="0,0,10,0"/>
                        <Button x:Name="ButtonBeginExport" Content="{DynamicResource StringBeginExport}" Click="BeginExport_Click"
                                Padding="15,8" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Clear All DAT Entries Tab -->
            <TabItem Header="{DynamicResource StringClearDatEntries}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Instructions -->
                    <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,15" Foreground="Black" xml:space="preserve"><Run FontWeight="Bold" Text="{DynamicResource StringClearDatDesc1}"/><LineBreak/><LineBreak/><Run Text="{DynamicResource StringClearDatDesc2}"/><LineBreak/><LineBreak/><Run Text="{DynamicResource StringImportDatDesc2}"/><LineBreak/><LineBreak/><Run Text="{DynamicResource StringClearDatDesc4}"/><Run FontWeight="Bold" Text="{DynamicResource StringClearDats}"/><Run Text="{DynamicResource StringImportDatDesc8}"/></TextBlock>

                    <!-- Button -->
                    <Button Grid.Row="1" Content="{DynamicResource StringClearDats}" Click="ClearDats_Click"
                            Padding="15,8" HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>

            <!-- Overwrite DATs With SD Card Tab -->
            <TabItem Header="{DynamicResource StringOverwriteDats}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Instructions -->
                    <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,15" Foreground="Black" xml:space="preserve"><Run FontWeight="Bold" Text="{DynamicResource StringOverwriteDatsDesc1}"/><LineBreak/><LineBreak/><Run Text="{DynamicResource StringOverwriteDatsDesc2}"/><LineBreak/><LineBreak/><Run Text="{DynamicResource StringOverwriteDatsDesc3}"/><Run FontWeight="Bold" Text="{DynamicResource StringOverwriteDatsDesc4}"/><Run Text="{DynamicResource StringOverwriteDatsDesc5}"/><LineBreak/><LineBreak/><Run Text="{DynamicResource StringOverwriteDatsDesc6}"/></TextBlock>

                    <!-- Button -->
                    <Button Grid.Row="1" Content="{DynamicResource StringOverwrite}" Click="OverwriteDats_Click"
                            Padding="15,8" HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
