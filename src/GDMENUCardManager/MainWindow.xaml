<Window x:Class="GDMENUCardManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GDMENUCardManager"
        xmlns:conv="clr-namespace:GDMENUCardManager.Converter"
        xmlns:core="clr-namespace:GDMENUCardManager.Core;assembly=GDMENUCardManager.Core"
        xmlns:dd="urn:gong-wpf-dragdrop"
        mc:Ignorable="d"
        Title="GD MENU Card Manager" Height="800" Width="960" MinHeight="400" MinWidth="960"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary>
            <conv:BoolToInverseBoolConverter x:Key="BoolToInverseBool"/>
            <conv:BoolToVisibleOrCollapsedConverter x:Key="BoolToVisibleOrCollapsed"/>
            <conv:BoolToVisibleOrHiddenConverter x:Key="BoolToVisibleOrHidden"/>
            <conv:NotNullToBoolConverter x:Key="NotNullToBool"/>
            <conv:FolderNumberConverter x:Key="FolderNumber"/>
            <conv:ByteSizeToStringConverter x:Key="ByteSizeToString"/>
            <conv:EnumToBoolConverter x:Key="EnumToBool"/>
            <conv:IsNotMenuItemConverter x:Key="IsNotMenuItem"/>
            <conv:IsGameDiscConverter x:Key="IsGameDisc"/>
            <conv:ArtworkButtonLabelConverter x:Key="ArtworkButtonLabel"/>
            <conv:IsOpenMenuModeConverter x:Key="IsOpenMenuMode"/>
            <conv:DriveInfoToLabelConverter x:Key="DriveInfoToLabel"/>
            <conv:BoolAndMultiValueConverter x:Key="BoolAndConverter"/>

            <!--icons from materialdesignicons.com-->
            <Viewbox x:Key="ViewOpenFolder" x:Shared="False" Width="18" Height="18" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
                <Canvas Width="24" Height="24">
                    <Path Data="M19,20H4C2.89,20 2,19.1 2,18V6C2,4.89 2.89,4 4,4H10L12,6H19A2,2 0 0,1 21,8H21L4,8V18L6.14,10H23.21L20.93,18.5C20.7,19.37 19.92,20 19,20Z" Fill="Black" />
                </Canvas>
            </Viewbox>
            <Viewbox x:Key="ViewRefresh" Width="18" Height="18" x:Shared="False" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
                <Canvas Width="24" Height="24">
                    <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Fill="Black" />
                </Canvas>
            </Viewbox>
            <Viewbox x:Key="ViewInfo" Width="18" Height="18" x:Shared="False" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
                <Canvas Width="24" Height="24">
                    <Path Data="M13.5,4A1.5,1.5 0 0,0 12,5.5A1.5,1.5 0 0,0 13.5,7A1.5,1.5 0 0,0 15,5.5A1.5,1.5 0 0,0 13.5,4M13.14,8.77C11.95,8.87 8.7,11.46 8.7,11.46C8.5,11.61 8.56,11.6 8.72,11.88C8.88,12.15 8.86,12.17 9.05,12.04C9.25,11.91 9.58,11.7 10.13,11.36C12.25,10 10.47,13.14 9.56,18.43C9.2,21.05 11.56,19.7 12.17,19.3C12.77,18.91 14.38,17.8 14.54,17.69C14.76,17.54 14.6,17.42 14.43,17.17C14.31,17 14.19,17.12 14.19,17.12C13.54,17.55 12.35,18.45 12.19,17.88C12,17.31 13.22,13.4 13.89,10.71C14,10.07 14.3,8.67 13.14,8.77Z" Fill="Black" />
                </Canvas>
            </Viewbox>
            <Viewbox x:Key="ViewAdd" Width="24" Height="24">
                <Canvas Width="24" Height="24">
                    <Path Fill="Black" Data="M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M13,7H11V11H7V13H11V17H13V13H17V11H13V7Z" />
                </Canvas>
            </Viewbox>
            <Viewbox x:Key="ViewRemove" Width="24" Height="24">
                <Canvas Width="24" Height="24">
                    <Path Fill="Black" Data="M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M7,13H17V11H7" />
                </Canvas>
            </Viewbox>
            <Viewbox x:Key="ViewMagnify" Width="20" Height="20">
                <Canvas Width="24" Height="24">
                    <Path Fill="Black" Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" />
                </Canvas>
            </Viewbox>
            <Viewbox x:Key="ViewFilter" Width="20" Height="20">
                <Canvas Width="24" Height="24">
                    <Path Fill="Black" Data="M14,12V19.88C14.04,20.18 13.94,20.5 13.71,20.71C13.32,21.1 12.69,21.1 12.3,20.71L10.29,18.7C10.06,18.47 9.96,18.16 10,17.87V12L4.21,4.62C3.87,4.19 3.95,3.56 4.38,3.22C4.57,3.08 4.78,3 5,3H19C19.22,3 19.43,3.08 19.62,3.22C20.05,3.56 20.13,4.19 19.79,4.62L14,12Z" />
                </Canvas>
            </Viewbox>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ProgressBar Grid.Row="0" Height="5" IsIndeterminate="{Binding IsBusy, Mode=OneWay}"/>

        <Grid Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
            <StackPanel Orientation="Horizontal">
                <Button Click="ButtonSpanish_Click" Padding="2" Background="Transparent" BorderThickness="0" ToolTip="Español">
                    <Image Source="pack://application:,,,/Assets/banderas/es.png" Width="24" Height="16"/>
                </Button>
                <Button Click="ButtonEnglish_Click" Padding="2" Background="Transparent" BorderThickness="0" ToolTip="English" Margin="5 0 0 0">
                    <Image Source="pack://application:,,,/Assets/banderas/gb.png" Width="24" Height="16"/>
                </Button>
            </StackPanel>
        </Grid>

        <GroupBox Grid.Row="1" Header="{DynamicResource StringSettings}" Margin="10" IsEnabled="{Binding IsBusy, Mode=OneWay, Converter={StaticResource BoolToInverseBool}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0" VerticalAlignment="Center" Content="{DynamicResource StringSDDrive}"/>
                    <Button Grid.Column="1" Width="30" Margin="10 0 0 0" Click="ButtonBrowseSdPath_Click" ToolTip="{DynamicResource StringBrowseSdTooltip}">
                        <ContentControl Content="{StaticResource ViewOpenFolder}" />
                    </Button>
                    <ComboBox Grid.Column="2" Width="150" VerticalContentAlignment="Center" ItemsSource="{Binding DriveList, Mode=OneWay}" SelectedItem="{Binding SelectedDrive, Mode=TwoWay}" ToolTip="{Binding SelectedDrive.VolumeLabel, Mode=OneWay}"
                              Visibility="{Binding IsUsingCustomPath, Converter={StaticResource BoolToVisibleOrCollapsed}, ConverterParameter=Inverse}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource DriveInfoToLabel}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBox Grid.Column="2" Width="150" VerticalContentAlignment="Center" Text="{Binding CustomSdPath, Mode=OneWay}" IsReadOnly="True"
                             Visibility="{Binding IsUsingCustomPath, Converter={StaticResource BoolToVisibleOrCollapsed}}"/>
                    <Button Grid.Column="3" Width="30" ToolTip="{DynamicResource StringRefreshDrive}" Click="ButtonRefreshDrive_Click">
                        <ContentControl Content="{StaticResource ViewRefresh}" />
                    </Button>
                </Grid>

                <Grid Grid.Column="1" Margin="30 0 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0" VerticalAlignment="Center" Content="{DynamicResource StringTempFolder}"/>

                    <Grid Grid.Column="1" Margin="10 0 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Width="30" Click="ButtonFolder_Click" ToolTip="{DynamicResource StringSelectFolder}">
                            <ContentControl Content="{StaticResource ViewOpenFolder}" />
                        </Button>
                        <TextBox Grid.Column="1" Width="200" VerticalContentAlignment="Center" Text="{Binding TempFolder, Mode=TwoWay}" IsReadOnly="True"/>
                        <Button Grid.Column="2" Width="30" Click="ButtonResetTempFolder_Click" ToolTip="{DynamicResource StringResetTempTooltip}">
                            <ContentControl Content="{StaticResource ViewRefresh}" />
                        </Button>
                    </Grid>
                </Grid>

                <Grid Grid.Column="2" Margin="30 0 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" VerticalAlignment="Center" Content="{DynamicResource StringMenuType}"/>
                    <Grid Grid.Column="1" Margin="10 0 0 0">
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <RadioButton Grid.Row="0" IsChecked="{Binding MenuKindSelected, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static core:MenuKind.gdMenu}}" ToolTip="Use gdMenu">gdMenu</RadioButton>
                        <RadioButton Grid.Row="1" IsChecked="{Binding MenuKindSelected, Mode=TwoWay, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static core:MenuKind.openMenu}}" ToolTip="Use openMenu">openMenu</RadioButton>
                    </Grid>
                </Grid>

                <Button Grid.Column="3" Width="30" Margin="30 0 0 0" HorizontalAlignment="Right" ToolTip="{DynamicResource StringAbout}" Click="ButtonAbout_Click">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Data="M11,9H13V7H11M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z" Fill="Black" />
                        </Canvas>
                    </Viewbox>
                </Button>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Margin="10 0 10 10" IsEnabled="{Binding IsBusy, Mode=OneWay, Converter={StaticResource BoolToInverseBool}}">
            <GroupBox.Header>
                <TextBlock>
                    <Run Text="{DynamicResource StringGamesList}"/> [<Run Text="{Binding TotalFilesLength, Mode=OneWay}"/>]
                </TextBlock>
            </GroupBox.Header>
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Grid DockPanel.Dock="Left" HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Label VerticalAlignment="Center" Content="{DynamicResource StringSearchFilter}"/>
                        <TextBox Grid.Column="1" x:Name="tbFilter" Width="200" Margin="10 0 0 0" MaxLength="256" VerticalContentAlignment="Center" Text="{Binding Filter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="2" Width="30" ToolTip="{DynamicResource StringSearchTooltip}" IsDefault="{Binding Path=IsFocused, ElementName=tbFilter, Mode=OneWay}" Click="ButtonSearch_Click">
                            <ContentControl Content="{StaticResource ViewMagnify}" />
                        </Button>
                        <Button Grid.Column="3" Width="30" ToolTip="{DynamicResource StringFilterTooltip}" Click="ButtonFilter_Click">
                            <ContentControl Content="{StaticResource ViewFilter}" />
                        </Button>
                        <Button Grid.Column="4" Width="30" ToolTip="{DynamicResource StringFilterResetTooltip}" Click="ButtonFilterReset_Click"
                                IsEnabled="{Binding IsFilterActive, Mode=OneWay}">
                            <ContentControl Content="{StaticResource ViewRefresh}" />
                        </Button>
                    </Grid>
                    <Button DockPanel.Dock="Right" HorizontalAlignment="Right" Padding="10 5" Margin="10 0 0 0" Click="ButtonBatchFolderRename_Click"
                            Visibility="{Binding MenuKindSelected, Converter={StaticResource IsOpenMenuMode}}" ToolTip="{DynamicResource StringBatchFolderRenameTooltip}" Content="{DynamicResource StringBatchFolderRename}">
                        <Button.IsEnabled>
                            <MultiBinding Converter="{StaticResource BoolAndConverter}">
                                <Binding Path="HasSdPath" Mode="OneWay"/>
                                <Binding Path="IsNotFilterActive" Mode="OneWay"/>
                            </MultiBinding>
                        </Button.IsEnabled>
                    </Button>
                    <Button DockPanel.Dock="Right" HorizontalAlignment="Right" Padding="10 5" Click="ButtonDiscImageOptions_Click" ToolTip="{DynamicResource StringDiscOptionsTooltip}"
                            IsEnabled="{Binding HasSdPath, Mode=OneWay}" Content="{DynamicResource StringDiscOptions}"/>
                    <Button DockPanel.Dock="Right" HorizontalAlignment="Right" Padding="10 5" Margin="0 0 10 0" Click="ButtonDatTools_Click"
                            Visibility="{Binding MenuKindSelected, Converter={StaticResource IsOpenMenuMode}}" ToolTip="{DynamicResource StringDatToolsTooltip}"
                            IsEnabled="{Binding HasSdPath, Mode=OneWay}" Content="{DynamicResource StringDatTools}"/>
                    <Button x:Name="ButtonSort" DockPanel.Dock="Right" HorizontalAlignment="Right" Padding="10 5" Margin="0 0 10 0" Click="ButtonSort_Click" ToolTip="{DynamicResource StringSortListTooltip}" Content="{DynamicResource StringSortList}">
                        <Button.IsEnabled>
                            <MultiBinding Converter="{StaticResource BoolAndConverter}">
                                <Binding Path="HasSdPath" Mode="OneWay"/>
                                <Binding Path="IsNotFilterActive" Mode="OneWay"/>
                            </MultiBinding>
                        </Button.IsEnabled>
                    </Button>
                </DockPanel>

                <DataGrid x:Name="dg1" ItemsSource="{Binding Manager.ItemList, Mode=OneTime}" AutoGenerateColumns="False" CanUserResizeRows="False" CanUserSortColumns="False" CanUserReorderColumns="False" CanUserAddRows="False" CanUserDeleteRows="{Binding IsBusy, Mode=OneWay, Converter={StaticResource BoolToInverseBool}}" dd:DragDrop.DropHandler="{Binding Path=., Mode=OneWay}" dd:DragDrop.IsDragSource="{Binding IsBusy, Mode=OneWay, Converter={StaticResource BoolToInverseBool}}" dd:DragDrop.IsDropTarget="{Binding IsBusy, Mode=OneWay, Converter={StaticResource BoolToInverseBool}}" PreviewKeyDown="DataGrid_PreviewKeyDown" BeginningEdit="DataGrid_BeginningEdit" CellEditEnding="DataGrid_CellEditEnding" Margin="0,0,0,8">
                    <DataGrid.Resources>
                        <ContextMenu x:Key="rowmenu" Opened="ContextMenu_Opened">
                            <ContextMenu.Items>
                                <MenuItem x:Name="MenuItemTitle" Header="{Binding Name, Mode=OneWay}" IsEnabled="False">
                                    <MenuItem.Icon>
                                        <Image Source="{StaticResource dreamcastLogoDrawingImage}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="{DynamicResource StringRename}" Click="MenuItemRename_Click" CommandParameter="{Binding Path=., Mode=OneWay}"/>
                                <MenuItem Header="{DynamicResource StringSentenceCase}" Click="MenuItemRenameSentence_Click" CommandParameter="{Binding Path=., Mode=OneWay}"/>
                                <MenuItem Header="{DynamicResource StringUppercase}" Click="MenuItemRenameUppercase_Click" CommandParameter="{Binding Path=., Mode=OneWay}"/>
                                <MenuItem Header="{DynamicResource StringLowercase}" Click="MenuItemRenameLowercase_Click" CommandParameter="{Binding Path=., Mode=OneWay}"/>
                                <MenuItem x:Name="MenuItemAutoRename" Header="{DynamicResource StringAutoRename}">
                                    <MenuItem Header="{DynamicResource StringUsingIP}" Click="MenuItemRenameIP_Click" CommandParameter="{Binding Path=., Mode=OneWay}"/>
                                    <MenuItem x:Name="MenuItemRenameFolder" Header="{DynamicResource StringUsingFolderComputer}" Click="MenuItemRenameFolder_Click" CommandParameter="{Binding Path=., Mode=OneWay}"/>
                                    <MenuItem x:Name="MenuItemRenameFile" Header="{DynamicResource StringUsingFileBase}" Click="MenuItemRenameFile_Click" CommandParameter="{Binding Path=., Mode=OneWay}"/>
                                </MenuItem>
                                <Separator/>
                                <MenuItem x:Name="MenuItemAssignFolder" Header="{DynamicResource StringAssignFolder}" Click="MenuItemAssignFolder_Click" CommandParameter="{Binding Path=., Mode=OneWay}"/>
                                <MenuItem x:Name="MenuItemAssignAltFolders" Header="{DynamicResource StringAssignAltFolders}" Click="MenuItemAssignAltFolders_Click" CommandParameter="{Binding Path=., Mode=OneWay}"/>
                            </ContextMenu.Items>
                        </ContextMenu>
                    </DataGrid.Resources>
                    <!--<DataGrid.RowStyle>
                    <Style>
                        <EventSetter Event="DataGridRow.MouseDoubleClick" Handler="DataGrid_MouseDoubleClick"/>
                    </Style>
                </DataGrid.RowStyle>-->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="ContextMenu" Value="{StaticResource rowmenu}" />
                            <Style.Triggers>
                                <!-- Disable context menu for menu entry (folder 01) -->
                                <DataTrigger Binding="{Binding SdNumber}" Value="1">
                                    <Setter Property="ContextMenu" Value="{x:Null}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Click="ButtonInfo_Click" ToolTip="{DynamicResource StringViewFileInfo}" CommandParameter="{Binding Path=., Mode=OneWay}" IsEnabled="{Binding Path=., Converter={StaticResource IsGameDisc}}">
                                        <ContentControl Content="{StaticResource ViewInfo}" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{DynamicResource StringLocation}" Width="60" IsReadOnly="True" Binding="{Binding Location, Mode=OneWay}"/>
                        <DataGridTextColumn Width="45" IsReadOnly="True" Binding="{Binding SdNumber, Mode=OneWay, Converter={StaticResource FolderNumber}}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource StringSdNumberShort}" ToolTip="{DynamicResource StringSdNumberTooltip}"/>
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="{DynamicResource StringLength}" Width="67" IsReadOnly="True" Binding="{Binding Length, Mode=OneWay, Converter={StaticResource ByteSizeToString}}"/>
                        <DataGridTextColumn x:Name="TitleColumn" Header="{DynamicResource StringTitle}" Width="2*" Binding="{Binding Name, Mode=TwoWay}"/>
                        <DataGridTemplateColumn x:Name="FolderColumn" Header="{DynamicResource StringFolder}" Width="1*" Visibility="Collapsed">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Folder, Mode=OneWay}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.Manager.KnownFolders, RelativeSource={RelativeSource AncestorType=Window}}"
                                              Text="{Binding Folder, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                              IsEditable="True"
                                              IsEnabled="{Binding Path=., Converter={StaticResource IsNotMenuItem}}"
                                              GotFocus="FolderComboBox_GotFocus"
                                              PreviewLostKeyboardFocus="FolderComboBox_PreviewLostKeyboardFocus"
                                              KeyDown="FolderComboBox_KeyDown"
                                              LostFocus="FolderComboBox_LostFocus"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{DynamicResource StringSerial}" Width="75" Binding="{Binding ProductNumber, Mode=TwoWay}"/>
                        <DataGridTemplateColumn x:Name="ArtColumn" Header="{DynamicResource StringArt}" Width="60" Visibility="Collapsed">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Click="ButtonArtwork_Click" CommandParameter="{Binding}"
                                            Content="{Binding HasArtwork, Converter={StaticResource ArtworkButtonLabel}}"
                                            Padding="5,2" MinWidth="55" HorizontalAlignment="Center">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="IsEnabled" Value="{Binding CanManageArtwork}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasArtwork}" Value="False">
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="ToolTip" Value="{DynamicResource StringAssignArtworkTooltip}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HasArtwork}" Value="True">
                                                        <Setter Property="ToolTip" Value="{DynamicResource StringEditArtworkTooltip}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsArtworkEnabled, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn x:Name="DiscColumn" Header="{DynamicResource StringDisc}" Width="45" IsReadOnly="True" Binding="{Binding Disc, Mode=TwoWay}"/>
                        <DataGridTemplateColumn x:Name="TypeColumn" Header="{DynamicResource StringType}" Width="80" Visibility="Collapsed">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DiscType, Mode=OneWay}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox SelectedItem="{Binding DiscType, Mode=TwoWay}">
                                        <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">Game</sys:String>
                                        <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">Other</sys:String>
                                        <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">PSX</sys:String>
                                    </ComboBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </GroupBox>

        <Grid Grid.Row="3" Margin="5 0 5 10" IsEnabled="{Binding IsBusy, Mode=OneWay, Converter={StaticResource BoolToInverseBool}}">

            <Grid IsEnabled="{Binding HasSdPath, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Width="50" Margin="10 0" ToolTip="{DynamicResource StringAddGames}" Click="ButtonAddGames_Click" Content="{StaticResource ViewAdd}" IsEnabled="{Binding IsNotFilterActive, Mode=OneWay}"/>
                <Button Grid.Column="1" Width="50" Margin="0 0 10 0" ToolTip="{DynamicResource StringRemoveGame}" Click="ButtonRemoveGame_Click" Content="{StaticResource ViewRemove}"/>
                <CheckBox Grid.Column="2" x:Name="cbLockCheck" VerticalAlignment="Center" Margin="10 0" IsChecked="{Binding EnableLockCheck, Mode=TwoWay}" ToolTip="{DynamicResource StringLockCheckTooltip}" Content="{DynamicResource StringLockCheck}"/>
                <Button Grid.Column="3" Margin="10 0" Padding="0 10" Click="ButtonSaveChanges_Click" FontWeight="Bold" ToolTip="{DynamicResource StringSaveChangesTooltip}" IsEnabled="{Binding IsNotFilterActive, Mode=OneWay}" Content="{DynamicResource StringSaveChanges}"/>
                <Button Grid.Column="4" Margin="0 0 5 0" Padding="10 10" Click="ButtonUndo_Click" ToolTip="{DynamicResource StringUndoTooltip}"
                        IsEnabled="{Binding Manager.UndoManager.CanUndo, Mode=OneWay}" Content="{DynamicResource StringUndo}"/>
                <Button Grid.Column="5" Margin="5 0 10 0" Padding="10 10" Click="ButtonRedo_Click" ToolTip="{DynamicResource StringRedoTooltip}"
                        IsEnabled="{Binding Manager.UndoManager.CanRedo, Mode=OneWay}" Content="{DynamicResource StringRedo}"/>
                <Button Grid.Column="6" Margin="10 0" Padding="10 10" ToolTip="{DynamicResource StringPreloadTooltip}" Click="ButtonPreload_Click" Visibility="Collapsed" Content="{DynamicResource StringPreload}"/>
                <Button Grid.Column="7" Margin="10 0" Padding="10 10" Click="ButtonSort_Click" Visibility="Collapsed" Content="{DynamicResource StringSortList}"/>
