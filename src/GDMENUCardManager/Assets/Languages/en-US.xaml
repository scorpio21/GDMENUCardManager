  <sys:String x:Key="StringClearDatEntries">Clear All DAT Entries</sys:String>
  <sys:String x:Key="StringClearDatDesc1">Clear all artwork and metadata from BOX.DAT, ICON.DAT, and META.DAT</sys:String>
  <sys:String x:Key="StringClearDatDesc2">Doing so will discard any unsaved artwork changes from Games List, as well as remove all saved entries.</sys:String>
