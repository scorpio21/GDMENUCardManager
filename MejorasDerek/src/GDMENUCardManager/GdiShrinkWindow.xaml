<Window x:Class="GDMENUCardManager.GdiShrinkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GDMENUCardManager"
        xmlns:conv="clr-namespace:GDMENUCardManager.Converter"
        mc:Ignorable="d"
        Title="GDI Shrink Selector" Height="400" Width="600" MinHeight="308" MinWidth="600"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <conv:ByteSizeToStringConverter x:Key="ByteSizeToString"/>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <DataGrid ItemsSource="{Binding List, Mode=OneTime}" IsReadOnly="True" AutoGenerateColumns="False" CanUserResizeRows="False" CanUserResizeColumns="False" CanUserSortColumns="False" CanUserReorderColumns="False" CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.Columns>

                <DataGridTemplateColumn Width="Auto" Header="Shrink">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" CommandParameter="{Binding Path=., Mode=OneTime}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Size" Width="Auto" Binding="{Binding Key.Length, Mode=OneTime, Converter={StaticResource ByteSizeToString}}"/>
                <DataGridTextColumn Header="Title" Width="1*" Binding="{Binding Key.Name, Mode=OneTime}"/>
                <DataGridTextColumn Header="Disc" Width="Auto" Binding="{Binding Key.Ip.Disc, Mode=OneTime}"/>
            </DataGrid.Columns>

        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 10 0 0">
            <Button Content="Select All" Width="110" Padding="15,8" Margin="0 0 10 0" Click="ButtonAll_Click"/>
            <Button Content="Select None" Width="110" Padding="15,8" Margin="0 0 10 0" Click="ButtonNone_Click"/>
            <Button Content="Proceed" Width="110" Padding="15,8" IsDefault="True" Click="ButtonShrink_Click"/>
        </StackPanel>

    </Grid>
</Window>
