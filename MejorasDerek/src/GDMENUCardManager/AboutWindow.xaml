<Window x:Class="GDMENUCardManager.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GDMENUCardManager"
        mc:Ignorable="d"
        Title="About" SizeToContent="Height" Width="680" ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <StackPanel>
            <!-- Header -->
            <TextBlock FontWeight="Bold" FontSize="16">GD MENU Card Manager - by Sonik (ateam version)</TextBlock>
            <TextBlock Margin="0,2,0,0">A tool to manage a GDEMU SD card and its contents</TextBlock>
            <TextBlock Margin="0,8,0,0">
                <Hyperlink RequestNavigate="Hyperlink_RequestNavigate" NavigateUri="https://github.com/DerekPascarella/openMenu-Virtual-Folder-Bundle">https://github.com/DerekPascarella/openMenu-Virtual-Folder-Bundle</Hyperlink>
            </TextBlock>

            <Separator Margin="0,12"/>

            <!-- Two-column content -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Vertical separator -->
                <Rectangle Grid.Column="1" Width="1" Fill="Gray" HorizontalAlignment="Center"/>

                <!-- Left Column -->
                <StackPanel Grid.Column="0">
                    <!-- Supported Formats -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap">Supported Formats</TextBlock>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold">Image</TextBlock>
                        <TextBlock Grid.Row="0" Grid.Column="1">GDI, CDI, CCD, MDS, CUE/BIN</TextBlock>
                        <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold">Compressed</TextBlock>
                        <TextBlock Grid.Row="1" Grid.Column="1">7Z, CHD, RAR, ZIP</TextBlock>
                    </Grid>

                    <Separator Margin="0,12"/>

                    <!-- Keyboard Shortcuts -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap">Keyboard Shortcuts</TextBlock>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold">Delete</TextBlock>
                        <TextBlock Grid.Row="0" Grid.Column="1">Remove selected item(s)</TextBlock>
                        <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold">Escape</TextBlock>
                        <TextBlock Grid.Row="1" Grid.Column="1">Close window</TextBlock>
                        <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="SemiBold">F2</TextBlock>
                        <TextBlock Grid.Row="2" Grid.Column="1">Rename selected item</TextBlock>
                        <TextBlock Grid.Row="3" Grid.Column="0" FontWeight="SemiBold">Ctrl+Z/Y</TextBlock>
                        <TextBlock Grid.Row="3" Grid.Column="1">Undo/Redo</TextBlock>
                    </Grid>

                    <Separator Margin="0,12"/>

                    <!-- Managing Games -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap">Managing Games</TextBlock>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold">Add</TextBlock>
                        <TextBlock Grid.Row="0" Grid.Column="1">[+] or drag and drop</TextBlock>
                        <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold">Remove</TextBlock>
                        <TextBlock Grid.Row="1" Grid.Column="1">[-] or Delete key</TextBlock>
                        <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="SemiBold">Reorder</TextBlock>
                        <TextBlock Grid.Row="2" Grid.Column="1">Drag and drop</TextBlock>
                        <TextBlock Grid.Row="3" Grid.Column="0" FontWeight="SemiBold">Sort</TextBlock>
                        <TextBlock Grid.Row="3" Grid.Column="1">[Sort List] button</TextBlock>
                    </Grid>

                    <Separator Margin="0,12"/>

                    <!-- Renaming -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap">Single or Bulk Renaming</TextBlock>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold">Manual</TextBlock>
                        <TextBlock Grid.Row="0" Grid.Column="1">Double-click, F2, or context menu</TextBlock>
                        <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold">Auto</TextBlock>
                        <TextBlock Grid.Row="1" Grid.Column="1">Context menu → Auto Rename</TextBlock>
                        <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="SemiBold">Case</TextBlock>
                        <TextBlock Grid.Row="2" Grid.Column="1">Title / Upper / Lower case</TextBlock>
                    </Grid>

                    <Separator Margin="0,12"/>

                    <!-- Folder Paths -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap">Folder Paths (openMenu mode)</TextBlock>
                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap">Context menu → Assign Folder Path to organize one or more games into a folder. Assign Additional Folder Paths to place a single game in up to five additional folders.</TextBlock>
                </StackPanel>

                <!-- Right Column -->
                <StackPanel Grid.Column="2">
                    <!-- Artwork -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap">Artwork (openMenu mode)</TextBlock>
                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap">Click Assign/Manage button in the Art column to set box art.</TextBlock>

                    <Separator Margin="0,12"/>

                    <!-- Batch Folder Move and Rename -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap">Batch Folder Move and Rename (openMenu mode)</TextBlock>
                    <TextBlock Margin="0,4,0,0">Reorganize folder hierarchy via tree view.</TextBlock>
                    <TextBlock>Double-click to rename, drag to reparent.</TextBlock>

                    <Separator Margin="0,12"/>

                    <!-- DAT Tools -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap">DAT Tools (openMenu mode)</TextBlock>
                    <TextBlock Margin="0,4,0,0">Import DAT Entries from external folder</TextBlock>
                    <TextBlock>Export Artwork to PNG files</TextBlock>
                    <TextBlock>Clear All DAT Entries</TextBlock>
                    <TextBlock>Overwrite DATs with SD card's DAT files</TextBlock>

                    <Separator Margin="0,12"/>

                    <!-- Disc Image Options -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap">Disc Image Options</TextBlock>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="SemiBold">GDI Shrink</TextBlock>
                        <TextBlock Grid.Row="0" Grid.Column="1">Reduce image size</TextBlock>
                        <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="SemiBold">VGA Patch</TextBlock>
                        <TextBlock Grid.Row="1" Grid.Column="1">Force VGA output</TextBlock>
                        <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="SemiBold">Region-Free</TextBlock>
                        <TextBlock Grid.Row="2" Grid.Column="1">Boot out-of-region games</TextBlock>
                    </Grid>

                    <Separator Margin="0,12"/>

                    <!-- File/Folder Lock Check -->
                    <TextBlock FontWeight="Bold" TextWrapping="Wrap">File/Folder Lock Check</TextBlock>
                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap">When enabled, checks all files and folders before saving to ensure nothing is locked by another process (e.g., File Explorer, antivirus). Disable if experiencing slow save times on large SD cards.</TextBlock>
                </StackPanel>
            </Grid>

            <Separator Margin="0,12"/>

            <!-- Credits -->
            <TextBlock FontWeight="Bold" TextWrapping="Wrap">Credits</TextBlock>
            <TextBlock Margin="0,4,0,0" TextWrapping="Wrap">GDEMU - Deunan; gdMenu - neuroacid; openMenu - mrneo240; GdiBuilder - Paul Kratt; GdiShrink - FamilyGuy; Aaru - Natalia Portillo; PuyoTools - Nick Woronekin; Redump2CDI - darc; gdidrop - feyris-tan; libchdr - Romain Tisserand; ImageSharp - SixLabors; ClosedXML - Jan Havlíček; 7z - Igor Pavlov; SevenZipSharp - Joel Ahlgren</TextBlock>
        </StackPanel>

        <!-- Check for Updates button (top-right, rendered after StackPanel so it's on top for clicks) -->
        <Button Content="Check for Updates" Click="CheckForUpdatesButton_Click"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Height="28" Padding="12 0"/>
    </Grid>
</Window>
