<Window x:Class="GDMENUCardManager.ArtworkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="450" Width="420" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Serial ID -->
        <TextBlock Grid.Row="0" Text="{Binding Serial}" FontWeight="Bold" Foreground="Black"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- Image Preview with Navigation Arrows -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Click="NavigatePrev_Click"
                    IsEnabled="{Binding CanNavigatePrev}"
                    VerticalAlignment="Center" Width="30" Height="40" Padding="0">
                <Path Data="M 10,0 L 0,8 L 10,16" Stroke="Black" StrokeThickness="2"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>

            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1"
                    Width="260" Height="260" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <TextBlock Text="No artwork assigned" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasPreviewImage}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Image Source="{Binding PreviewImage}" Stretch="Uniform">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasPreviewImage}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Grid>
            </Border>

            <Button Grid.Column="2" Click="NavigateNext_Click"
                    IsEnabled="{Binding CanNavigateNext}"
                    VerticalAlignment="Center" Width="30" Height="40" Padding="0">
                <Path Data="M 0,0 L 10,8 L 0,16" Stroke="Black" StrokeThickness="2"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
        </Grid>

        <!-- Info Label -->
        <TextBlock Grid.Row="2" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,10,0,0" Foreground="Black">
            <Run Text="Artwork changes aren't written to DAT files until clicking "/><Run Text="Save Changes" FontWeight="Bold"/><Run Text=" in the main window."/>
        </TextBlock>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Browse for Image" Click="BrowseImage_Click" Margin="0,0,10,0" Padding="15,8"/>
            <Button Content="Delete Entry" Click="DeleteEntry_Click" Margin="0,0,10,0" Padding="15,8"
                    IsEnabled="{Binding CanDelete}"/>
            <Button Content="Save" Click="Apply_Click" Padding="15,8"
                    IsEnabled="{Binding HasUnsavedChanges}"/>
        </StackPanel>
    </Grid>
</Window>
